# Database
DATABASE_URL=postgresql+asyncpg://garrison:garrison@db:5432/garrison

# Redis (ARQ worker broker)
REDIS_URL=redis://redis:6379

# Auth
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encryption key for RCON passwords (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=change-me-generate-a-real-key

# CORS
CORS_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT=60/minute

# Discord Integration (optional)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=

# Discord OAuth2 (optional — enables "Link with Discord" button)
# Use the same application as your bot in the Discord Developer Portal
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost/api/auth/discord/callback

# Steam API (optional — enables VAC ban checks and player enrichment)
# Get your key at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
